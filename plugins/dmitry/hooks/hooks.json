{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Dmitry plugin loaded'",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "env > /tmp/dmitry-hook-env.txt && echo '{}'",
            "async": false
          }
        ]
      }
    ]
  }
}
